  {
    "id": "tab_dashboard",
    "type": "tab",
    "label": "Node-RED Dashboard",
    "disabled": false,
    "info": "Live monitoring dashboard built in Node-RED. Shows per-machine KPIs, alarm counts, and OEE."
  },

  {
    "id": "mqtt_in_summary",
    "type": "mqtt in",
    "z": "tab_dashboard",
    "name": "Subscribe: factory/summary",
    "topic": "factory/summary",
    "qos": "0",
    "datatype": "json",
    "broker": "mqtt_broker_local",
    "nl": false,
    "rap": true,
    "rh": 0,
    "inputs": 0,
    "x": 160,
    "y": 100,
    "wires": [["fn_summary_extract"]]
  },

  {
    "id": "fn_summary_extract",
    "type": "function",
    "z": "tab_dashboard",
    "name": "Extract KPIs",
    "func": "const s = msg.payload;\nconst msgs = [\n  { payload: s.running,              topic: 'running' },\n  { payload: s.faulted,              topic: 'faulted' },\n  { payload: s.avg_oee_pct,          topic: 'oee' },\n  { payload: s.total_throughput_pph, topic: 'throughput' },\n  { payload: s.active_alerts,        topic: 'alerts' },\n  { payload: s.total_power_kw,       topic: 'power' },\n];\nreturn [msgs];",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 380,
    "y": 100,
    "wires": [["ui_text_running", "ui_chart_oee", "ui_gauge_throughput"]]
  },

  {
    "id": "mqtt_in_alerts_dash",
    "type": "mqtt in",
    "z": "tab_dashboard",
    "name": "Subscribe: factory/alerts/#",
    "topic": "factory/alerts/#",
    "qos": "2",
    "datatype": "json",
    "broker": "mqtt_broker_local",
    "nl": false,
    "rap": true,
    "rh": 0,
    "inputs": 0,
    "x": 160,
    "y": 200,
    "wires": [["fn_format_alert"]]
  },

  {
    "id": "fn_format_alert",
    "type": "function",
    "z": "tab_dashboard",
    "name": "Format Alert for UI",
    "func": "const a = msg.payload;\nconst ts = new Date(a.timestamp * 1000).toTimeString().slice(0,8);\nmsg.payload = `[${ts}] ${a.machine_id} — ${a.code}: ${a.message}`;\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 400,
    "y": 200,
    "wires": [["ui_text_alert"]]
  },

  {
    "id": "ui_text_running",
