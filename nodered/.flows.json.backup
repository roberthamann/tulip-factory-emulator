  {
    "id": "mqtt_broker_local",
    "type": "mqtt-broker",
    "name": "Local Mosquitto",
    "broker": "mosquitto",
    "port": "1883",
    "clientid": "nodered-edge-device",
    "autoConnect": true,
    "usetls": false,
    "protocolVersion": "4",
    "keepalive": "60",
    "cleansession": true,
    "autoUnsubscribe": true,
    "birthTopic": "nodered/status",
    "birthQos": "0",
    "birthRetain": "false",
    "birthPayload": "online",
    "birthMsg": {},
    "closeTopic": "nodered/status",
    "closeQos": "0",
    "closeRetain": "false",
    "closePayload": "offline",
    "closeMsg": {},
    "willTopic": "nodered/status",
    "willQos": "0",
    "willRetain": "false",
    "willPayload": "lost",
    "willMsg": {},
    "userProps": "",
    "sessionExpiry": ""
  }
]
