    "id": "mqtt_out_state",
    "type": "mqtt out",
    "z": "tab_edge_device",
    "name": "Publish: factory/{line}/{machine}/state",
    "topic": "",
    "qos": "0",
    "retain": "false",
    "respTopic": "",
    "contentType": "",
    "userProps": "",
    "correl": "",
    "expiry": "",
    "broker": "mqtt_broker_local",
